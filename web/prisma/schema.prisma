generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  pubkey    String   @unique
  username  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  deletedAt DateTime?

  points Int @default(0)

  verificationLevel Int     @default(1)
  phone             String? @unique
  phoneVerified     Boolean @default(false)
  email             String?
  country           String?
  tosAccepted       Boolean @default(false)

  alternativeIdType      String?
  alternativeIdNumber    String?
  alternativeIdImageUrl  String?
  alternativeIdVerified  Boolean @default(false)

  endorsementCode      String?
  selfieVerified       Boolean @default(false)
  governmentIdVerified Boolean @default(false)
  kycPartner           String?

  verificationReviews VerificationReview[]

  vaults      Vault[]
  invitations Invitation[]
  logs        ActivityLog[]
  memberships VaultMember[]
  sentTransfers     PendingTransfer[] @relation("SentTransfers")
  receivedTransfers PendingTransfer[] @relation("ReceivedTransfers")

  trustScore                Int @default(0)
  savingsGoalsCompleted     Int @default(0)
  onTimeDeposits            Int @default(0)
  collaborativeVaultsCount  Int @default(0)
  disputesCount             Int @default(0)
}

model Vault {
  id           String   @id @default(cuid())
  name         String
  description  String?
  goalType     String
  targetAmount Float
  ownerPubkey  String
  createdAt    DateTime @default(now())

  contractAddress String
  onChainVaultId   BigInt
  vaultType        String
  balance          Float     @default(0)
  status           String    @default("Active")
  lockUntil        DateTime?

  owner       User          @relation(fields: [ownerPubkey], references: [pubkey])
  invitations Invitation[]
  logs        ActivityLog[]
  members     VaultMember[]
  proposals VaultProposal []

  @@unique([contractAddress, onChainVaultId])
}

model VaultProposal {
  id         String   @id @default(cuid())
  vaultId    String
  proposedBy String
  type       String   // "edit_goal" | "edit_lock" | "delete"
  changes    Json?    // { targetAmount? } for edit_goal | { lockUntil? } for edit_lock | null for delete
  status     String   @default("pending") // pending | approved | rejected | executed
  createdAt  DateTime @default(now())

  vault     Vault                   @relation(fields: [vaultId], references: [id])
  approvals VaultProposalApproval[]
}

model VaultProposalApproval {
  id         String   @id @default(cuid())
  proposalId String
  pubkey     String
  createdAt  DateTime @default(now())

  proposal VaultProposal @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, pubkey])
}

model VaultMember {
  id        String   @id @default(cuid())
  vaultId   String
  pubkey    String
  role      String   @default("Contributor")
  addedAt   DateTime @default(now())

  vault Vault @relation(fields: [vaultId], references: [id])
  user  User  @relation(fields: [pubkey], references: [pubkey])

  @@unique([vaultId, pubkey])
}

model Invitation {
  id            String   @id @default(cuid())
  vaultId       String
  invitedBy     String
  inviteePubkey String
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  vault   Vault @relation(fields: [vaultId], references: [id])
  inviter User  @relation(fields: [invitedBy], references: [pubkey])
}

model Notification {
  id        String   @id @default(cuid())
  pubkey    String
  message   String
  read      Boolean  @default(false)
  vaultId   String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  vaultId   String?
  pubkey    String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  vault Vault? @relation(fields: [vaultId], references: [id])
  user  User   @relation(fields: [pubkey], references: [pubkey])
}

model Challenge {
  pubkey     String   @id
  challenge  String
  expiresAt  DateTime
}

model PendingTransfer {
  id                String   @id @default(cuid())
  senderPubkey      String
  recipientPubkey   String
  amount            Float
  senderAuthorized  Boolean  @default(false)
  receiverAuthorized Boolean @default(false)
  status            String   @default("awaiting_authorization")
  createdAt         DateTime @default(now())

  sender    User @relation("SentTransfers", fields: [senderPubkey], references: [pubkey])
  recipient User @relation("ReceivedTransfers", fields: [recipientPubkey], references: [pubkey])
}

model VerificationReview {
  id         String   @id @default(cuid())
  userId     String
  level      Int
  decision   String
  reason     String?
  reviewedBy String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}