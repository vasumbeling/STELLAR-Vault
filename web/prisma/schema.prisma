generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  pubkey    String   @unique
  username  String?
  avatarUrl String?
  createdAt DateTime @default(now())

  vaults      Vault[]
  invitations Invitation[]
  logs        ActivityLog[]
}

model Vault {
  id           String   @id @default(cuid())
  name         String
  description  String?
  goalType     String
  targetAmount Float
  ownerPubkey  String
  createdAt    DateTime @default(now())

  // --- On-chain fields (added to match the Soroban contract) ---
  contractAddress String    // the single deployed VaultContract's address (shared across many vaults)
  onChainVaultId   BigInt    // the u64 vault_id returned by the contract's create_vault call
  vaultType        String    // "Personal" | "Collaborative" — mirrors the contract's VaultType enum
  balance          Float     @default(0)         // mirrors the contract's on-chain balance
  status           String    @default("Active")  // "Active" | "GoalReached" | "Closed"
  lockUntil        DateTime? // null = no lock, matches contract's lock_until of 0

  owner       User          @relation(fields: [ownerPubkey], references: [pubkey])
  invitations Invitation[]
  logs        ActivityLog[]

  // A given contract can only have one vault with a given on-chain ID
  @@unique([contractAddress, onChainVaultId])
}

model Invitation {
  id            String   @id @default(cuid())
  vaultId       String
  invitedBy     String
  inviteePubkey String
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  vault   Vault @relation(fields: [vaultId], references: [id])
  inviter User  @relation(fields: [invitedBy], references: [pubkey])
}

model Notification {
  id        String   @id @default(cuid())
  pubkey    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  vaultId   String?
  pubkey    String
  action    String
  detail    String?
  createdAt DateTime @default(now())

  vault Vault? @relation(fields: [vaultId], references: [id])
  user  User   @relation(fields: [pubkey], references: [pubkey])
}